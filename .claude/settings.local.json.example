{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm run *)",
      "Bash(now-sdk *)",
      "Bash(npx @servicenow/sdk explain *)"
    ]
  },
  "mcpServers": {
    "jira": {
      "command": "npx",
      "args": ["-y", "jira-mcp"],
      "env": {
        "JIRA_INSTANCE_URL": "https://your-org.atlassian.net",
        "JIRA_USER_EMAIL": "your@email.com",
        "JIRA_API_KEY": "your-api-token"
      }
    }
  }
}
